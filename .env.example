# Asterisk ARI (backend connects to Asterisk server)
# Two-server: Asterisk = 103.187.23.17, Backend = 103.159.37.176 → use 103.187.23.17 below (and in Docker).
ARI_URL=http://103.187.23.17:8088
ARI_USER=myariuser
ARI_PASS=change-me
ARI_APP=myapp

# Asterisk AMI
AMI_HOST=103.187.23.17
AMI_PORT=5038
AMI_USER=myamiuser
